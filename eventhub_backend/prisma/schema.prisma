// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String @id @default(uuid())
  firstName String
  lastName  String
  email     String @unique
  phone     String
  role      String
  password  String
  salt      String
}

model Event {
  id          String      @id @default(uuid())
  title       String
  description String
  date        DateTime
  capacity    Float
  price       Float
  imageUrl    String[]    @default([])
  organizer   String
  venue       String
  category    String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Organizer {
  id      String @id @default(uuid())
  name    String
  eventId String
}

model Venue {
  id       String @id @default(uuid())
  address  String
  capacity Float
  eventId  String
}

model Category {
  id       String   @id @default(uuid())
  category String[]
  eventId  String
}
