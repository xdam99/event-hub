{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2021",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "../*": ["src/*"]
    },
    "incremental": true,
    "skipLibCheck": true
  },
  "include": ["src", "tests"]
}